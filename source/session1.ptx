<!-- ....................................... SECTION 1 ...................................... -->
<worksheet><title>Getting Warmed Up and In the Right Mindset...</title>
  <image width="20%">
    <shortdescription>
      This is an image
    </shortdescription>
    <latex-image>
      \begin{tikzpicture}
        \draw (0,0) rectangle (1,1);
